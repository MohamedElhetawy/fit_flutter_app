rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function userDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function userData() {
      return userDoc().data;
    }

    function role() {
      return userData().role;
    }

    function statusActive() {
      return userData().status == 'active';
    }

    function sameGym(gymId) {
      return gymId != null && userData().gymId != null && gymId == userData().gymId;
    }

    function isSuperAdmin() {
      return role() == 'super_admin';
    }

    function hasRole(r) {
      return role() == r;
    }

    function hasPermission(permission) {
      return isSuperAdmin()
        || userData().permissions[permission] == true
        || (
          role() == 'admin' && (
            permission in [
              'users.read',
              'users.create',
              'users.update',
              'users.delete',
              'subscriptions.manage',
              'reports.view'
            ]
          )
        )
        || (
          role() == 'trainer' && (
            permission in [
              'users.read',
              'users.update',
              'reports.view'
            ]
          )
        )
        || (
          role() == 'user' && permission == 'reports.view'
        )
        || (
          role() == 'support' && (
            permission in [
              'users.read',
              'reports.view'
            ]
          )
        );
    }

    function canReadOwn(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    function canReadUserDoc(uid) {
      return canReadOwn(uid)
        || (signedIn() && statusActive() && hasPermission('users.read'));
    }

    match /users/{uid} {
      allow read: if canReadUserDoc(uid)
        && (
          isSuperAdmin()
          || canReadOwn(uid)
          || sameGym(resource.data.gymId)
          || hasRole('support')
        );

      allow create: if signedIn()
        && statusActive()
        && hasPermission('users.create');

      allow update: if signedIn()
        && statusActive()
        && (
          canReadOwn(uid)
          || hasPermission('users.update')
        )
        && (
          isSuperAdmin()
          || canReadOwn(uid)
          || sameGym(resource.data.gymId)
        );

      allow delete: if signedIn()
        && statusActive()
        && hasPermission('users.delete')
        && (isSuperAdmin() || sameGym(resource.data.gymId));
    }

    match /workouts/{workoutId} {
      allow read: if signedIn() && statusActive();

      allow create, update, delete: if signedIn()
        && statusActive()
        && (
          isSuperAdmin()
          || hasRole('admin')
          || hasRole('trainer')
        )
        && (
          isSuperAdmin()
          || sameGym(request.resource.data.gymId)
        );
    }

    match /subscriptions/{subscriptionId} {
      allow read: if signedIn()
        && statusActive()
        && (
          isSuperAdmin()
          || hasPermission('subscriptions.manage')
          || resource.data.userId == request.auth.uid
          || sameGym(resource.data.gymId)
        );

      allow create, update, delete: if signedIn()
        && statusActive()
        && hasPermission('subscriptions.manage')
        && (
          isSuperAdmin()
          || sameGym(request.resource.data.gymId)
        );
    }

    match /roles/{roleId} {
      allow read: if signedIn() && statusActive();
      allow write: if signedIn() && statusActive() && isSuperAdmin();
    }

    match /permissions/{permissionId} {
      allow read: if signedIn() && statusActive() && hasPermission('users.read');
      allow write: if signedIn() && statusActive() && isSuperAdmin();
    }

    match /dashboard_admin_stats/{docId} {
      allow read: if signedIn() && statusActive() && hasPermission('reports.view');
      allow write: if signedIn() && statusActive() && (isSuperAdmin() || hasRole('admin'));
    }

    match /dashboard_trainer_stats/{uid} {
      allow read: if signedIn()
        && statusActive()
        && (
          request.auth.uid == uid
          || isSuperAdmin()
          || hasRole('admin')
        );
      allow write: if signedIn() && statusActive() && (isSuperAdmin() || hasRole('admin'));
    }

    match /dashboard_user_stats/{uid} {
      allow read: if signedIn()
        && statusActive()
        && (
          request.auth.uid == uid
          || hasRole('trainer')
          || hasRole('admin')
          || isSuperAdmin()
        );
      allow write: if signedIn() && statusActive() && (isSuperAdmin() || hasRole('admin'));
    }
  }
}
